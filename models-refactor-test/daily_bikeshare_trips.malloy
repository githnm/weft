source: daily_bikeshare_trips is bigquery.table('bigquery-public-data.austin_bikeshare.daily_bikeshare_trips') extend {

  dimension: trip_date_month is trip_date.month

  measure: row_count is count()
  measure: total_num_trips is num_trips.sum()

  view: by_trip_date is {
    group_by: trip_date
    aggregate: row_count, total_num_trips
    limit: 10
  }
}
