# Path to a Google Cloud service account JSON key file.
# If not set, falls back to Application Default Credentials
# (i.e. whatever `gcloud auth application-default login` configured).
GOOGLE_APPLICATION_CREDENTIALS=

# GCP project ID to bill BigQuery queries to.
# Required — queries need a billing project even when reading public data.
BQ_PROJECT_ID=your-gcp-project

# Postgres connection string (only for Postgres warehouses).
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=no-verify

# Anthropic API key — required for model building, asking, and suggestions.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the Claude model.
# Default: claude-sonnet-4-5-20250929
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Optional: where Weft keeps its local state (connections, substrates, models).
# Defaults to <repo>/.weft — resolved from the install location, so the CLI,
# web app, and MCP server all agree with no configuration. Set only to relocate.
# WEFT_HOME=/absolute/path/to/.weft
